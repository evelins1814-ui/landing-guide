{
  "title": "Компания · Название вакансии",
  "description": "Короткое описание вакансии (используется для отладки и og-тегов).",
  "sdk_version": "1.0",
  "custom_events": ["hero_apply_cta", "mid_apply_cta", "footer_apply_cta", "watch_director_video"],
  "form": {
    "submit_label": "Отправить отклик",
    "fields": [
      {"name": "applicant_name", "type": "text",     "required": true,  "role": "name",  "label": "Имя и фамилия"},
      {"name": "contact_phone",  "type": "tel",      "required": true,  "role": "phone", "label": "Телефон"},
      {"name": "email",          "type": "email",    "required": false, "role": "email", "label": "Email"},
      {"name": "telegram",       "type": "text",     "required": false, "label": "Telegram"},
      {"name": "age",            "type": "number",   "required": false, "min": 16, "max": 80, "label": "Возраст"},
      {"name": "experience",     "type": "text",     "required": false, "label": "Опыт в основном навыке, лет"},
      {"name": "video",          "type": "file",     "required": false, "accept": "video/*", "max_size_mb": 60, "label": "Видео-визитка"}
    ]
  }
}
